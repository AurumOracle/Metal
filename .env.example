# API Keys
GOLDAPI_KEY=your_goldapi_key_here
COINGECKO_API_KEY=optional

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/aurum_oracle

# Algorand
NEXT_PUBLIC_ALGORAND_NETWORK=testnet
NEXT_PUBLIC_ALGORAND_SERVER=https://testnet-api.algonode.cloud
NEXT_PUBLIC_ALGORAND_INDEXER=https://testnet-idx.algonode.cloud
NEXT_PUBLIC_ALGORAND_PORT=443

# Smart Contracts (filled after deploy.py)
NEXT_PUBLIC_XPC_ASA_ID=
NEXT_PUBLIC_MARKET_CONTRACT_ID=
NEXT_PUBLIC_TREASURY_CONTRACT_ID=
NEXT_PUBLIC_ORACLE_ADDRESS=

# NFD
NEXT_PUBLIC_NFD_PARENT_DOMAIN=xpc.algo
NFD_WRITE_KEY=optional_for_segment_minting

# Auth
SESSION_SECRET=your_random_32_byte_hex_here

# Feature Flags
NEXT_PUBLIC_ENABLE_PREMIUM=true
NEXT_PUBLIC_ENABLE_TRADING=true
